# Environment Variables Configuration
# Copy this file to .env and fill in your actual values
# The .env file is loaded automatically by dotenv in the scripts

# Google API Configuration
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_CLOUD_PROJECT=your_google_cloud_project_id_here

# Instagram Credentials (for browsing examples)
INSTAGRAM_EMAIL=your_instagram_email@example.com
INSTAGRAM_PASSWORD=your_instagram_password_here

# Proxy Configuration (for BQT examples)
PROXY_URL=your_proxy_url_here
# Example format: brd-customer-hl_XXXXX-zone-static:XXXXX@brd.superproxy.io:33335

# Database Configuration (for BQT examples)
DB_USERNAME=your_database_username
DB_PASSWORD=your_database_password

