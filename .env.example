# NetGent example environment file.
# Copy to `.env` (loaded last; lowest priority) or `.env.{environment}` / `.env.{environment}.local`
# for env-specific overrides. See src/core/config.py for the full priority chain.
#
# Anything left commented out falls back to the default declared in `Settings`.

# ── Application ───────────────────────────────────────────────────────────────

# development | staging | production | test  (shorthand: prod, stage)
NETGENT_ENV=development
# DEBUG=false
# PROJECT_NAME=NetGent
# VERSION=0.1.0

# ── Logging ───────────────────────────────────────────────────────────────────

# DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_LEVEL=INFO
# json | console
# LOG_FORMAT=console

# ── Execution (substrate worker namespace) ───────────────────────────────────

# When false, actions are wrapped in `nsenter ... ip netns exec <ns>`.
# USE_LOCAL=true
# LINUX_NAMESPACE=ns1

# ── LLM providers ────────────────────────────────────────────────────────────

# anthropic | gemini
# NETGENT_LLM_PROVIDER=gemini
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── Browser-use / Playwright ─────────────────────────────────────────────────

# BROWSER_USE_HEADLESS=true
# BROWSER_USE_MAX_STEPS=30
# BROWSER_USE_MAX_REPAIR_ATTEMPTS=2
# NETGENT_DISABLE_STEALTH=false
# When set, browser actions connect to a remote Browserless instance over CDP
# instead of launching a local Chromium. Example:
#   wss://chrome.browserless.io?token=<TOKEN>
# BROWSERLESS_WS_ENDPOINT=
