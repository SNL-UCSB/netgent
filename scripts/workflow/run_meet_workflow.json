{
  "specification": "1. Go to https://meet.google.com/{{meeting_code}}\n2. On the pre-join screen, type {{display_name}} into the 'Your name' input.\n3. Click 'Ask to join' to request entry to the meeting.\n4. Once in the lobby or meeting, wait for {{wait_seconds}} seconds before stopping.",
  "states": [
    {
      "checks": [
        {
          "type": "always_true",
          "params": {}
        }
      ],
      "actions": [
        {
          "type": "go_to_url",
          "params": {
            "url": "https://meet.google.com/{{meeting_code}}",
            "new_tab": false
          }
        },
        {
          "type": "input_text",
          "params": {
            "selector": "input[aria-label=\"Your name\"]",
            "text": "{{display_name}}"
          }
        },
        {
          "type": "click_element",
          "params": {
            "selector": "button:has-text(\"Join now\")"
          }
        },
        {
          "type": "wait",
          "params": {
            "seconds": "{{wait_seconds}}"
          }
        }
      ],
      "end_state": "Workflow Completed",
      "executed": []
    }
  ],
  "parameters": ["meeting_code", "display_name", "wait_seconds"]
}
