      {
        "type": "type",
        "params": {
          "text": "%address%",
          "by": "css selector",
          "selector": "input.input.is-large.street.ui-autocomplete-input[placeholder*=\"Search For Your Address\"][required=\"required\"][type=\"text\"][name=\"locate[address]\"][id=\"locate_address\"][autocomplete=\"address-line1\"]",
          "x": 311.3828125,
          "y": 447.78125
        }
      },
      {
        "type": "type",
        "params": {
          "text": "%zip_code%",
          "by": "css selector",
          "selector": "input.input.is-large.zip[placeholder*=\"Zip Code\"][required=\"required\"][type=\"text\"][name=\"locate[zip]\"][id=\"locate_zip\"][autocomplete=\"postal-code\"]",
          "x": 835.2578125,
          "y": 447.78125
        }
      },
      {
        "type": "click",
        "params": {
          "by": "css selector",
          "selector": "select[id=\"\"][name=\"locate[service_class]\"][required=\"\"]",
          "x": 1041.0078125,
          "y": 446.7734375
        }
      },
      {
        "type": "press_key",
        "params": {
          "key": "down"
        }
      },
      {
        "type": "press_key",
        "params": {
          "key": "enter"
        }
      },
      {
        "type": "click",
        "params": {
          "by": "css selector",
          "selector": "input.button.is-primary.is-large.address_search_button[type=\"submit\"][name=\"commit\"]",
          "x": 1199.12890625,
          "y": 446.7734375
        }
      },
      {
        "type": "terminate",
        "params": {
          "reason": "Task completed successfully"
        }
      }
    ],
    "end_state": "",
    "executed": []
  },
